---
export const prerender = true;
import Layout from "../layouts/LayoutSeo.astro";
import Navbar from "../components/organismos/Navbar.astro";
import Section from "../components/organismos/Section.astro";
import TituloColores from "../components/atomos/TituloColores.astro";
import { db } from "../db/client";
import { servicios as serviciosSchema } from "../db/schema";

const allServicios = await db.select().from(serviciosSchema);
const serviciosData = allServicios.sort(
  (a, b) => (a.orden || 99) - (b.orden || 99),
);
---

<Layout
  title="Que hacemos | Servicios interdisciplinarios - Simi Sumaq"
  description="Brindamos cirugia reconstructiva, fonoaudiologia y apoyo psicologico-social para una atencion integral."
  canonical="https://asociacionsimisumaq.org/que-hacemos"
>
  <Section
    isBackgroundFoto
    srcFotoBackground="/banner1.webp"
    id="hero"
    class="bg-linear-to-r from-primary-100 to-primary-200"
  >
    <div class="text-center text-primary-textoTitle py-20">
      <TituloColores>Qué Hacemos</TituloColores>
      <p class="text-xl md:text-2xl max-w-3xl mx-auto opacity-90">
        Brindamos un tratamiento integral e interdisciplinario para transformar
        y seguir multiplicando sonrisas.
      </p>
    </div>
  </Section>

  <Section id="servicios" class="py-24 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12">
        {
          serviciosData?.map((servicio, index) => (
            <div class="bg-primary-bg-claro p-8 rounded-2xl hover:shadow-medium transition-all border border-transparent hover:border-primary-100">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-12 h-12 rounded-full bg-primary-100 text-white flex items-center justify-center font-bold text-xl shrink-0">
                  {index + 1}
                </div>
                <h3 class="text-2xl font-bold text-primary-textoTitle">
                  {servicio.titulo}
                </h3>
              </div>
              <p class="text-primary-textoBody mb-6 leading-relaxed">
                {servicio.descripcion}
              </p>
              <ul class="space-y-2">
                {JSON.parse(servicio.items || "[]").map((item: string) => (
                  <li class="flex items-center gap-2 text-primary-texto">
                    <span class="w-2 h-2 rounded-full bg-primary-200" />
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </Section>

  <Section id="enfoque" class="py-24 bg-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-primary-textoTitle mb-8">
        Nuestro Enfoque Interdisciplinario
      </h2>
      <p class="text-xl text-primary-textoBody leading-relaxed mb-12">
        Entendemos que la fisura labiopalatina requiere una mirada completa. No
        tratamos solo una condición física, sino que acompañamos el desarrollo
        integral del niño, asegurando que pueda comer, hablar, oír y sonreír con
        total plenitud. Nuestro equipo trabaja de manera coordinada para que
        cada etapa del tratamiento sea un paso firme hacia un futuro lleno de
        oportunidades.
      </p>
    </div>
  </Section>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/organismos/Navbar.astro";
import Section from "../components/organismos/Section.astro";
import { User } from "lucide-react";

const equipo = [
  {
    nombre: "Cramaro Carolina",
    cargo: "Médica cirujana infantil",
    detalle: "Coordinadora Médica",
  },
  { nombre: "Abaca Thiago", cargo: "Licenciado en Fonoaudiología" },
  { nombre: "Acosta Leonardo", cargo: "Profesor" },
  { nombre: "Diaz Soledad", cargo: "Coordinadora de grupo de Padres" },
  { nombre: "Ferreyra Luis", cargo: "Coordinador de Traslados" },
  { nombre: "Gallardo Andrea", cargo: "Licenciada en Fonoaudiología" },
  { nombre: "Mansilla Mariana", cargo: "Licenciada en Psicología" },
  { nombre: "Miranda Luz", cargo: "Voluntaria" },
  { nombre: "Pereyra Carlina", cargo: "Trabajadora Social" },
  { nombre: "Roldan Xiomara", cargo: "Licenciada en Psicopedagogía" },
  {
    nombre: "Umaño Exequiel",
    cargo: "Fotografo",
    detalle: "Comunicación Institucional",
  },
];

const comisionDirectiva = [
  { cargo: "Presidente" },
  { cargo: "Secretario" },
  { cargo: "Tesorero" },
  { cargo: "Vocal 1" },
  { cargo: "Vocal 2" },
  { cargo: "Revisora de Cuenta" },
];
---

<Layout>
  <Section
    isBackgroundFoto
    srcFotoBackground="https://scontent.cdninstagram.com/v/t39.30808-6/568562079_1555866042517659_2240020214404568880_n.jpg?stp=c0.1.1920.1280a_dst-jpg_e35_s1080x1080_tt6&_nc_cat=103&ig_cache_key=Mzc0ODM2MzY2ODIzMzg3NDk3MA%3D%3D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjE5MjB4MTI4Mi5zZHIuQzMifQ%3D%3D&_nc_ohc=a9ebwiJ1puYQ7kNvwFAJnv9&_nc_oc=AdkDVcPTlgwkQBC9BjH90LgmL52EKHqWArZEAHz043DEu0lidyS-fZLBur1QEWMToOo&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=scontent.cdninstagram.com&_nc_gid=xgw30uDoRDwYnCnajBPQrQ&oh=00_AflOtoXk52H2AAnSYq_I0xOB6FcGBbWVmXCM-aLkQfQrlA&oe=69352ED9"
    id="hero"
    class="bg-linear-to-r from-primary-100 to-primary-200"
  >
    <div class="text-center text-primary-textoTitle py-20">
      <h1 class="text-5xl md:text-6xl font-bold mb-6">Nuestro Equipo</h1>
      <p class="text-xl md:text-2xl max-w-3xl mx-auto opacity-90">
        Profesionales comprometidos trabajando con el corazón
      </p>
    </div>
  </Section>

  <Section id="equipo" class="py-24 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          equipo.map((miembro) => (
            <div class="bg-white p-8 rounded-2xl shadow-subtle hover:shadow-medium transition-all text-center border border-primary-border flex flex-col items-center">
              <div class="w-24 h-24 mb-6 rounded-full bg-linear-to-br from-primary-100/10 to-primary-200/10 flex items-center justify-center">
                <User className="h-10 w-10 text-primary-100" />
              </div>
              <h3 class="text-xl font-bold text-primary-textoTitle mb-2">
                {miembro.nombre}
              </h3>
              <p class="text-primary-100 font-semibold mb-1">{miembro.cargo}</p>
              {miembro.detalle && (
                <p class="text-sm text-muted-foreground italic">
                  {miembro.detalle}
                </p>
              )}
            </div>
          ))
        }
      </div>

      <div class="mt-20 text-center">
        <p class="text-muted-foreground max-w-2xl mx-auto text-lg">
          Además, contamos con una red de voluntarios y colaboradores que hacen
          posible cada una de nuestras actividades y campañas brindando
          esperanza a cada familia.
        </p>
      </div>
    </div>  </Section>

  <Section id="comision-directiva" class="py-24 bg-primary-bg-claro">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold text-primary-textoTitle mb-4">
          Autoridades Comision Directiva
        </h2>
        <p class="text-lg text-primary-textoBody">
          Conoce los cargos que conforman nuestra comision directiva
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          comisionDirectiva.map((directivo) => (
            <div class="bg-white p-8 rounded-2xl shadow-subtle hover:shadow-medium transition-all text-center border border-primary-border flex flex-col items-center">
              <div class="w-24 h-24 mb-6 rounded-full bg-linear-to-br from-primary-100/10 to-primary-200/10 flex items-center justify-center">
                <User className="h-10 w-10 text-primary-100" />
              </div>
              <h3 class="text-xl font-bold text-primary-textoTitle">
                {directivo.cargo}
              </h3>
            </div>
          ))
        }
      </div>
    </div>
  </Section>
</Layout>

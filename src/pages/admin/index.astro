        </div>
      </div>
    </a>

    <a
      href="/admin/servicios"
      class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-md transition-shadow"
    >
      <div class="flex items-center gap-4">
        <div
          class="w-12 h-12 rounded-lg bg-cyan-50 flex items-center justify-center"
        >
          <svg
            class="h-6 w-6 text-cyan-600"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
            ></path>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold text-gray-900">{serviciosCount}</p>
          <p class="text-sm text-gray-500">Servicios</p>
        </div>
      </div>
    </a>
  </div>
</AdminLayout>

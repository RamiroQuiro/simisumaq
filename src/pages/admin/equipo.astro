---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { db } from "../../db/client";
import { equipo } from "../../db/schema";

const items = await db.select().from(equipo);
---

<AdminLayout title="Equipo">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Equipo</h1>
      <p class="text-gray-500 mt-1">{items.length} miembros</p>
    </div>
    <button
      id="btn-create"
      class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-gradient-to-r from-red-500 to-orange-500 text-white text-sm font-medium hover:from-red-600 hover:to-orange-600 transition-all"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      Nuevo miembro
    </button>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200 bg-gray-50">
            <th class="text-left px-4 py-3 font-medium text-gray-600">Foto</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Nombre</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Cargo</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600 hidden sm:table-cell">Detalle</th>
            <th class="text-right px-4 py-3 font-medium text-gray-600">Acciones</th>
          </tr>
        </thead>
        <tbody>
          {items.map((item) => (
            <tr class="border-b border-gray-100 last:border-b-0 hover:bg-gray-50">
              <td class="px-4 py-3">
                {item.foto ? (
                  <img src={item.foto} alt={item.nombre} class="w-10 h-10 rounded-full object-cover border border-gray-200" />
                ) : (
                  <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-gray-400">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                  </div>
                )}
              </td>
              <td class="px-4 py-3 font-medium text-gray-900">{item.nombre}</td>
              <td class="px-4 py-3 text-gray-600">{item.cargo}</td>
              <td class="px-4 py-3 text-gray-500 hidden sm:table-cell">{item.detalle || "-"}</td>
              <td class="px-4 py-3 text-right">
                <div class="flex items-center justify-end gap-2">
                  <button
                    class="btn-edit p-1.5 rounded-lg text-gray-400 hover:text-blue-600 hover:bg-blue-50 transition-colors"
                    data-id={item.id}
                    data-nombre={item.nombre}
                    data-cargo={item.cargo}
                    data-foto={item.foto || ""}
                    data-detalle={item.detalle || ""}
                  >
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                  </button>
                  <button
                    class="btn-delete p-1.5 rounded-lg text-gray-400 hover:text-red-600 hover:bg-red-50 transition-colors"
                    data-id={item.id}
                    data-nombre={item.nombre}
                  >
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Create Modal -->
  <div id="create-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" id="create-overlay"></div>
    <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-md p-6">
      <h3 class="text-lg font-semibold text-gray-900 mb-4">Nuevo miembro del equipo</h3>
      <form id="create-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Nombre *</label>
          <input type="text" name="nombre" required class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Cargo *</label>
          <input type="text" name="cargo" required class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Foto</label>
          <div id="create-dropzone" class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center hover:border-red-400 transition-colors cursor-pointer">
            <svg class="h-8 w-8 text-gray-400 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-sm text-gray-500">Click o arrastrá una imagen</p>
            <p class="text-xs text-gray-400 mt-1">JPG, PNG, WebP o GIF. Máx 5MB.</p>
            <input type="file" name="foto" accept="image/*" class="hidden" id="create-file-input" />
          </div>
          <div id="create-preview" class="mt-3 flex justify-center"></div>
          <input type="hidden" name="foto_url" id="create-foto-url" value="" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Detalle</label>
          <input type="text" name="detalle" class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent" />
        </div>
        <div id="create-upload-status" class="hidden text-sm text-center py-2"></div>
        <div class="flex gap-3 pt-2">
          <button type="button" class="btn-cancel-create flex-1 px-4 py-2.5 rounded-lg border border-gray-300 text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors">
            Cancelar
          </button>
          <button type="submit" id="create-submit" class="flex-1 px-4 py-2.5 rounded-lg bg-gradient-to-r from-red-500 to-orange-500 text-white text-sm font-medium hover:from-red-600 hover:to-orange-600 transition-all">
            Crear
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Edit Modal -->
  <div id="edit-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" id="edit-overlay"></div>
    <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-md p-6">
      <h3 class="text-lg font-semibold text-gray-900 mb-4">Editar miembro</h3>
      <form id="edit-form" class="space-y-4">
        <input type="hidden" name="id" id="edit-id" />
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Nombre *</label>
          <input type="text" name="nombre" id="edit-nombre" required class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Cargo *</label>
          <input type="text" name="cargo" id="edit-cargo" required class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Foto actual</label>
          <div id="edit-current-photo" class="flex items-center gap-3 mb-2"></div>
          <input type="hidden" name="foto_url" id="edit-foto-url" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Cambiar foto</label>
          <div id="edit-dropzone" class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center hover:border-red-400 transition-colors cursor-pointer">
            <svg class="h-8 w-8 text-gray-400 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-sm text-gray-500">Click o arrastrá una nueva imagen</p>
            <input type="file" accept="image/*" class="hidden" id="edit-file-input" />
          </div>
          <div id="edit-preview" class="mt-3 flex justify-center"></div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Detalle</label>
          <input type="text" name="detalle" id="edit-detalle" class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent" />
        </div>
        <div id="edit-upload-status" class="hidden text-sm text-center py-2"></div>
        <div class="flex gap-3 pt-2">
          <button type="button" class="btn-cancel-edit flex-1 px-4 py-2.5 rounded-lg border border-gray-300 text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors">
            Cancelar
          </button>
          <button type="submit" id="edit-submit" class="flex-1 px-4 py-2.5 rounded-lg bg-gradient-to-r from-red-500 to-orange-500 text-white text-sm font-medium hover:from-red-600 hover:to-orange-600 transition-all">
            Guardar
          </button>
        </div>
      </form>
    </div>
  </div>

  <script is:inline>
    async function uploadFile(file) {
      const formData = new FormData();
      formData.append("file", file);
      const res = await fetch("/api/upload", { method: "POST", body: formData });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error);
      return data.url;
    }

    function setupDropzone(dropzoneId, inputId, previewId, hiddenInputId) {
      const dropzone = document.getElementById(dropzoneId);
      const input = document.getElementById(inputId);
      const preview = document.getElementById(previewId);
      const hiddenInput = document.getElementById(hiddenInputId);

      dropzone.addEventListener("click", () => input.click());
      dropzone.addEventListener("dragover", (e) => { e.preventDefault(); dropzone.classList.add("border-red-400", "bg-red-50"); });
      dropzone.addEventListener("dragleave", () => { dropzone.classList.remove("border-red-400", "bg-red-50"); });
      dropzone.addEventListener("drop", (e) => {
        e.preventDefault();
        dropzone.classList.remove("border-red-400", "bg-red-50");
        if (e.dataTransfer.files.length) { input.files = e.dataTransfer.files; input.dispatchEvent(new Event("change")); }
      });
      input.addEventListener("change", () => {
        if (input.files.length) {
          const file = input.files[0];
          const thumb = document.createElement("div");
          thumb.className = "relative w-24 h-24 rounded-lg overflow-hidden border border-gray-200";
          thumb.innerHTML = '<img class="w-full h-full object-cover" />';
          thumb.querySelector("img").src = URL.createObjectURL(file);
          preview.innerHTML = "";
          preview.appendChild(thumb);
        }
      });
    }

    setupDropzone("create-dropzone", "create-file-input", "create-preview", "create-foto-url");
    setupDropzone("edit-dropzone", "edit-file-input", "edit-preview", "edit-foto-url");

    document.getElementById("btn-create").addEventListener("click", () => {
      document.getElementById("create-preview").innerHTML = "";
      document.getElementById("create-foto-url").value = "";
      document.getElementById("create-modal").classList.remove("hidden");
    });
    document.getElementById("create-overlay").addEventListener("click", () => {
      document.getElementById("create-modal").classList.add("hidden");
    });
    document.querySelectorAll(".btn-cancel-create").forEach(b => b.addEventListener("click", () => {
      document.getElementById("create-modal").classList.add("hidden");
    }));

    document.getElementById("create-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      const form = e.target;
      const fileInput = document.getElementById("create-file-input");
      const status = document.getElementById("create-upload-status");
      const submitBtn = document.getElementById("create-submit");

      submitBtn.disabled = true;

      try {
        let fotoUrl = document.getElementById("create-foto-url").value;
        if (fileInput.files.length && !fotoUrl) {
          status.textContent = "Subiendo imagen...";
          status.className = "text-sm text-center py-2 text-gray-500";
          status.classList.remove("hidden");
          fotoUrl = await uploadFile(fileInput.files[0]);
        }

        const formData = new FormData(form);
        formData.set("foto", fotoUrl || "");
        await fetch("/api/equipo", { method: "POST", body: formData });
        window.location.reload();
      } catch (err) {
        status.textContent = err.message;
        status.className = "text-sm text-center py-2 text-red-600";
        submitBtn.disabled = false;
      }
    });

    document.querySelectorAll(".btn-edit").forEach(btn => {
      btn.addEventListener("click", () => {
        document.getElementById("edit-id").value = btn.dataset.id;
        document.getElementById("edit-nombre").value = btn.dataset.nombre;
        document.getElementById("edit-cargo").value = btn.dataset.cargo;
        document.getElementById("edit-detalle").value = btn.dataset.detalle;

        const currentFoto = btn.dataset.foto;
        document.getElementById("edit-foto-url").value = currentFoto;

        const photoContainer = document.getElementById("edit-current-photo");
        photoContainer.innerHTML = "";
        if (currentFoto) {
          photoContainer.innerHTML = `
            <img src="${currentFoto}" class="w-16 h-16 rounded-full object-cover border border-gray-200" />
            <button type="button" id="remove-photo" class="text-xs text-red-600 hover:text-red-700">Quitar foto</button>
          `;
          document.getElementById("remove-photo").addEventListener("click", () => {
            document.getElementById("edit-foto-url").value = "";
            photoContainer.innerHTML = '<span class="text-sm text-gray-400">Sin foto</span>';
          });
        } else {
          photoContainer.innerHTML = '<span class="text-sm text-gray-400">Sin foto</span>';
        }

        document.getElementById("edit-preview").innerHTML = "";
        document.getElementById("edit-file-input").value = "";
        document.getElementById("edit-modal").classList.remove("hidden");
      });
    });
    document.getElementById("edit-overlay").addEventListener("click", () => {
      document.getElementById("edit-modal").classList.add("hidden");
    });
    document.querySelectorAll(".btn-cancel-edit").forEach(b => b.addEventListener("click", () => {
      document.getElementById("edit-modal").classList.add("hidden");
    }));

    document.getElementById("edit-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      const fileInput = document.getElementById("edit-file-input");
      const status = document.getElementById("edit-upload-status");
      const submitBtn = document.getElementById("edit-submit");

      submitBtn.disabled = true;

      try {
        let fotoUrl = document.getElementById("edit-foto-url").value;
        if (fileInput.files.length) {
          status.textContent = "Subiendo nueva imagen...";
          status.className = "text-sm text-center py-2 text-gray-500";
          status.classList.remove("hidden");
          fotoUrl = await uploadFile(fileInput.files[0]);
        }

        const id = document.getElementById("edit-id").value;
        const data = {
          nombre: document.getElementById("edit-nombre").value,
          cargo: document.getElementById("edit-cargo").value,
          foto: fotoUrl || null,
          detalle: document.getElementById("edit-detalle").value || null,
        };
        await fetch("/api/equipo?id=" + id, {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });
        window.location.reload();
      } catch (err) {
        status.textContent = err.message;
        status.className = "text-sm text-center py-2 text-red-600";
        submitBtn.disabled = false;
      }
    });

    document.querySelectorAll(".btn-delete").forEach(btn => {
      btn.addEventListener("click", async () => {
        if (!confirm('¿Eliminar a "' + btn.dataset.nombre + '"?')) return;
        await fetch("/api/equipo?id=" + btn.dataset.id, { method: "DELETE" });
        window.location.reload();
      });
    });
  </script>
</AdminLayout>

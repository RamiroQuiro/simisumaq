---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { db } from "../../db/client";
import { servicios } from "../../db/schema";

const allServicios = await db.select().from(servicios);
const items = allServicios.sort((a, b) => (a.orden || 99) - (b.orden || 99));
---

<AdminLayout title="Servicios">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Servicios</h1>
      <p class="text-gray-500 mt-1">{items.length} servicios</p>
    </div>
    <button
      id="btn-create"
      class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-gradient-to-r from-red-500 to-orange-500 text-white text-sm font-medium hover:from-red-600 hover:to-orange-600 transition-all"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      Nuevo servicio
    </button>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200 bg-gray-50">
            <th class="text-left px-4 py-3 font-medium text-gray-600">Orden</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Título</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600 hidden md:table-cell">Items</th>
            <th class="text-right px-4 py-3 font-medium text-gray-600">Acciones</th>
          </tr>
        </thead>
        <tbody>
          {items.map((item) => (
            <tr class="border-b border-gray-100 last:border-b-0 hover:bg-gray-50">
              <td class="px-4 py-3 text-gray-500">{item.orden || 99}</td>
              <td class="px-4 py-3 font-medium text-gray-900">{item.titulo}</td>
              <td class="px-4 py-3 text-gray-500 hidden md:table-cell">
                {(() => {
                  const parsedItems = JSON.parse(item.items || "[]");
                  return `${parsedItems.length} items`;
                })()}
              </td>
              <td class="px-4 py-3 text-right">
                <div class="flex items-center justify-end gap-2">
                  <button
                    class="btn-edit p-1.5 rounded-lg text-gray-400 hover:text-blue-600 hover:bg-blue-50 transition-colors"
                    data-id={item.id}
                    data-titulo={item.titulo}
                    data-descripcion={item.descripcion}
                    data-items={item.items}
                    data-orden={item.orden || 99}
                    data-cover={item.cover || ""}
                  >
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                  </button>
                  <button
                    class="btn-delete p-1.5 rounded-lg text-gray-400 hover:text-red-600 hover:bg-red-50 transition-colors"
                    data-id={item.id}
                    data-titulo={item.titulo}
                  >
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Create Modal -->
  <div id="create-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" id="create-overlay"></div>
    <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-lg p-6 max-h-[90vh] overflow-y-auto">
      <h3 class="text-lg font-semibold text-gray-900 mb-4">Nuevo servicio</h3>
      <form id="create-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Título *</label>
          <input type="text" name="titulo" required class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Descripción *</label>
          <textarea name="descripcion" required rows="3" class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Items (uno por línea)</label>
          <textarea name="items" rows="5" class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent" placeholder={"Queiloplastia\nPalatoplastia\nInjertos óseos"}></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Foto de portada (opcional)</label>
          <div id="create-cover-dropzone" class="border-2 border-dashed border-gray-300 rounded-lg p-4 text-center hover:border-red-400 transition-colors cursor-pointer">
            <svg class="h-6 w-6 text-gray-400 mx-auto mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-sm text-gray-500">Click o arrastrá una imagen</p>
            <input type="file" accept="image/*" class="hidden" id="create-cover-input" />
          </div>
          <div id="create-cover-preview" class="mt-2 flex justify-center"></div>
          <input type="hidden" name="cover" id="create-cover-url" value="" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Orden</label>
          <input type="number" name="orden" value="10" class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent" />
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button" class="btn-cancel-create flex-1 px-4 py-2.5 rounded-lg border border-gray-300 text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors">
            Cancelar
          </button>
          <button type="submit" class="flex-1 px-4 py-2.5 rounded-lg bg-gradient-to-r from-red-500 to-orange-500 text-white text-sm font-medium hover:from-red-600 hover:to-orange-600 transition-all">
            Crear
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Edit Modal -->
  <div id="edit-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="fixed inset-0 bg-black/50" id="edit-overlay"></div>
    <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-lg p-6 max-h-[90vh] overflow-y-auto">
      <h3 class="text-lg font-semibold text-gray-900 mb-4">Editar servicio</h3>
      <form id="edit-form" class="space-y-4">
        <input type="hidden" name="id" id="edit-id" />
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Título *</label>
          <input type="text" name="titulo" id="edit-titulo" required class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Descripción *</label>
          <textarea name="descripcion" id="edit-descripcion" required rows="3" class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Items (uno por línea)</label>
          <textarea name="items" id="edit-items" rows="5" class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Portada actual</label>
          <div id="edit-cover-current" class="mb-2"></div>
          <input type="hidden" name="cover" id="edit-cover-url" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Cambiar portada</label>
          <div id="edit-cover-dropzone" class="border-2 border-dashed border-gray-300 rounded-lg p-4 text-center hover:border-red-400 transition-colors cursor-pointer">
            <svg class="h-6 w-6 text-gray-400 mx-auto mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-sm text-gray-500">Nueva imagen de portada</p>
            <input type="file" accept="image/*" class="hidden" id="edit-cover-input" />
          </div>
          <div id="edit-cover-preview" class="mt-2 flex justify-center"></div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Orden</label>
          <input type="number" name="orden" id="edit-orden" class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent" />
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button" class="btn-cancel-edit flex-1 px-4 py-2.5 rounded-lg border border-gray-300 text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors">
            Cancelar
          </button>
          <button type="submit" class="flex-1 px-4 py-2.5 rounded-lg bg-gradient-to-r from-red-500 to-orange-500 text-white text-sm font-medium hover:from-red-600 hover:to-orange-600 transition-all">
            Guardar
          </button>
        </div>
      </form>
    </div>
  </div>

  <script is:inline>
    async function uploadFile(file) {
      const formData = new FormData();
      formData.append("file", file);
      const res = await fetch("/api/upload", { method: "POST", body: formData });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error);
      return data.url;
    }

    function setupSingleDropzone(dropzoneId, inputId, previewId, hiddenInputId) {
      const dropzone = document.getElementById(dropzoneId);
      const input = document.getElementById(inputId);
      const preview = document.getElementById(previewId);
      dropzone.addEventListener("click", () => input.click());
      dropzone.addEventListener("dragover", (e) => { e.preventDefault(); dropzone.classList.add("border-red-400", "bg-red-50"); });
      dropzone.addEventListener("dragleave", () => { dropzone.classList.remove("border-red-400", "bg-red-50"); });
      dropzone.addEventListener("drop", (e) => {
        e.preventDefault();
        dropzone.classList.remove("border-red-400", "bg-red-50");
        if (e.dataTransfer.files.length) { input.files = e.dataTransfer.files; input.dispatchEvent(new Event("change")); }
      });
      input.addEventListener("change", () => {
        if (input.files.length) {
          const file = input.files[0];
          const thumb = document.createElement("div");
          thumb.className = "relative w-24 h-16 rounded-lg overflow-hidden border border-gray-200";
          thumb.innerHTML = '<img class="w-full h-full object-cover" />';
          thumb.querySelector("img").src = URL.createObjectURL(file);
          preview.innerHTML = "";
          preview.appendChild(thumb);
        }
      });
    }

    setupSingleDropzone("create-cover-dropzone", "create-cover-input", "create-cover-preview", "create-cover-url");
    setupSingleDropzone("edit-cover-dropzone", "edit-cover-input", "edit-cover-preview", "edit-cover-url");

    document.getElementById("btn-create").addEventListener("click", () => {
      document.getElementById("create-cover-url").value = "";
      document.getElementById("create-cover-preview").innerHTML = "";
      document.getElementById("create-modal").classList.remove("hidden");
    });
    document.getElementById("create-overlay").addEventListener("click", () => {
      document.getElementById("create-modal").classList.add("hidden");
    });
    document.querySelectorAll(".btn-cancel-create").forEach(b => b.addEventListener("click", () => {
      document.getElementById("create-modal").classList.add("hidden");
    }));

    document.getElementById("create-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      const form = e.target;
      try {
        let coverUrl = document.getElementById("create-cover-url").value;
        const coverInput = document.getElementById("create-cover-input");
        if (coverInput.files.length && !coverUrl) {
          coverUrl = await uploadFile(coverInput.files[0]);
        }
        const formData = new FormData(form);
        formData.set("cover", coverUrl || "");
        await fetch("/api/servicios", { method: "POST", body: formData });
        window.location.reload();
      } catch (err) {
        alert(err.message);
      }
    });

    document.querySelectorAll(".btn-edit").forEach(btn => {
      btn.addEventListener("click", () => {
        document.getElementById("edit-id").value = btn.dataset.id;
        document.getElementById("edit-titulo").value = btn.dataset.titulo;
        document.getElementById("edit-descripcion").value = btn.dataset.descripcion;
        const parsedItems = JSON.parse(btn.dataset.items || "[]");
        document.getElementById("edit-items").value = parsedItems.join("\n");
        document.getElementById("edit-orden").value = btn.dataset.orden;

        const currentCover = btn.dataset.cover || "";
        document.getElementById("edit-cover-url").value = currentCover;
        const coverContainer = document.getElementById("edit-cover-current");
        coverContainer.innerHTML = "";
        if (currentCover) {
          coverContainer.innerHTML = `
            <div class="relative w-32 h-20 rounded-lg overflow-hidden border border-gray-200 group/cover">
              <img class="w-full h-full object-cover" src="${currentCover}" />
              <button type="button" class="absolute inset-0 bg-red-500/70 text-white text-xs opacity-0 group-hover/cover:opacity-100 transition-opacity" id="remove-cover">✕ Quitar</button>
            </div>
          `;
          document.getElementById("remove-cover").addEventListener("click", () => {
            document.getElementById("edit-cover-url").value = "";
            coverContainer.innerHTML = '<span class="text-sm text-gray-400">Sin portada</span>';
          });
        } else {
          coverContainer.innerHTML = '<span class="text-sm text-gray-400">Sin portada</span>';
        }
        document.getElementById("edit-cover-preview").innerHTML = "";
        document.getElementById("edit-modal").classList.remove("hidden");
      });
    });
    document.getElementById("edit-overlay").addEventListener("click", () => {
      document.getElementById("edit-modal").classList.add("hidden");
    });
    document.querySelectorAll(".btn-cancel-edit").forEach(b => b.addEventListener("click", () => {
      document.getElementById("edit-modal").classList.add("hidden");
    }));

    document.getElementById("edit-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      const id = document.getElementById("edit-id").value;
      const itemsStr = document.getElementById("edit-items").value;
      const items = itemsStr.split("\n").map(s => s.trim()).filter(Boolean);
      try {
        let coverUrl = document.getElementById("edit-cover-url").value;
        const coverInput = document.getElementById("edit-cover-input");
        if (coverInput.files.length) {
          coverUrl = await uploadFile(coverInput.files[0]);
        }
        const data = {
          titulo: document.getElementById("edit-titulo").value,
          descripcion: document.getElementById("edit-descripcion").value,
          items: JSON.stringify(items),
          orden: parseInt(document.getElementById("edit-orden").value) || 99,
          cover: coverUrl || null,
        };
        await fetch("/api/servicios?id=" + id, {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });
        window.location.reload();
      } catch (err) {
        alert(err.message);
      }
    });

    document.querySelectorAll(".btn-delete").forEach(btn => {
      btn.addEventListener("click", async () => {
        if (!confirm('¿Eliminar "' + btn.dataset.titulo + '"?')) return;
        await fetch("/api/servicios?id=" + btn.dataset.id, { method: "DELETE" });
        window.location.reload();
      });
    });
  </script>
</AdminLayout>

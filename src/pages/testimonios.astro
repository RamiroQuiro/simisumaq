---
import Layout from "../layouts/Layout.astro";
import Section from "../components/organismos/Section.astro";
import TituloColores from "../components/atomos/TituloColores.astro";
import { db } from "../db/client";
import { testimonios } from "../db/schema";

const allTestimonios = await db.select().from(testimonios);

const iconColors = [
  "from-primary-100 to-primary-200",
  "from-primary-200 to-amber-400",
  "from-rose-400 to-primary-100",
];
---

<Layout title="Testimonios | Simi Sumaq" description="Conoce las experiencias e historias de las familias que forman parte de la comunidad Simi Sumaq." canonical="https://asociacionsimisumaq.org/testimonios">
  <Section
    isBackgroundFoto
    srcFotoBackground="/banner1.webp"
    id="hero"
    class="bg-linear-to-r from-primary-100 to-primary-200"
  >
    <div class="text-center text-primary-textoTitle py-20">
      <TituloColores>Testimonios</TituloColores>
      <p class="text-xl md:text-2xl max-w-3xl mx-auto opacity-90">
        Las voces de nuestras familias son el motor que nos impulsa a seguir multiplicando sonrisas.
      </p>
    </div>
  </Section>

  <Section id="testimonios" class="py-24 bg-white">
    <div class="max-w-6xl mx-auto">
      {
        allTestimonios.length > 0 ? (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {allTestimonios.map((testimonio, index) => (
              <div class="group relative bg-white rounded-2xl border border-primary-border p-8 hover:shadow-medium transition-all duration-300 hover:-translate-y-1">
                <div class="absolute -top-4 left-8">
                  <div class={`w-10 h-10 rounded-full bg-gradient-to-br ${iconColors[index % iconColors.length]} flex items-center justify-center shadow-subtle`}>
                    <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
                    </svg>
                  </div>
                </div>
                <div class="pt-6">
                  <p class="text-primary-textoBody leading-relaxed mb-6 italic">
                    "{testimonio.texto}"
                  </p>
                  <div class="flex items-center gap-4 pt-4 border-t border-primary-border">
                    <div class={`w-12 h-12 rounded-full bg-gradient-to-br ${iconColors[index % iconColors.length]} flex items-center justify-center text-white font-bold text-lg shrink-0`}>
                      {testimonio.nombre.charAt(0)}
                    </div>
                    <div>
                      <p class="font-semibold text-primary-textoTitle">
                        {testimonio.nombre}
                      </p>
                      <p class="text-sm text-primary-texto">
                        {testimonio.rol}
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="text-center py-16">
            <p class="text-xl text-primary-texto">
              Próximamente compartiremos las experiencias de nuestra comunidad.
            </p>
          </div>
        )
      }
    </div>
  </Section>
</Layout>

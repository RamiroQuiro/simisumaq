---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/organismos/Navbar.astro";
import Section from "../components/organismos/Section.astro";
import { Image, Video, Filter } from "lucide-react";

const imagenes = [
  { id: "1", nombre: "Todas", path: "/galeria/1.webp" },
  { id: "2", nombre: "Cirugías", path: "/galeria/2.webp" },
  { id: "3", nombre: "Talleres", path: "/galeria/3.webp" },
  { id: "4", nombre: "Eventos", path: "/galeria/4.webp" },
  { id: "5", nombre: "Testimonios", path: "/galeria/5.webp" },
];
---

<Layout>
  <div class="text-center text-primary-textoTitle py-32">
    <h1 class="text-5xl md:text-6xl font-bold mb-6">Galería</h1>
    <p class="text-xl md:text-2xl max-w-3xl mx-auto opacity-90">
      Cada imagen cuenta una historia de esperanza, amor y sonrisas recuperadas
    </p>
  </div>

  <Section id="ejemplo" class="py-24 bg-white">
    <div class="max-w-6xl mx-auto">
      <h3 class="text-2xl font-bold text-primary-textoTitle mb-8 text-center">
        Vista Previa del Diseño de Galería
      </h3>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {
          imagenes.map((item) => (
            <div class="aspect-square bg-linear-to-br from-primary-100/20 to-primary-200/20 rounded-xl border-2 border-dashed border-primary-100 flex items-center justify-center hover:scale-105 transition-transform cursor-pointer">
              <img
                src={item.path}
                alt={item.nombre}
                class="w-full h-full object-cover"
              />
            </div>
          ))
        }
      </div>

      
    </div>
  </Section>

  <Section
    id="cta"
    class="py-24 bg-linear-to-r from-primary-100 to-primary-200"
  >
    <div class="max-w-4xl mx-auto text-center text-primary-textoTitle">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">Comparte Tu Historia</h2>
      <p class="text-xl mb-8 opacity-90">
        Si eres parte de la familia Simi Sumaq y quieres compartir tu
        experiencia, contáctanos
      </p>
      <a
        href="/contacto"
        class="inline-flex items-center justify-center rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 w-fit disabled:opacity-50 disabled:cursor-not-allowed duration-200 bg-primary-100 text-primary-800 hover:bg-primary-150 hover:text-white focus:ring-primary-150 border-primary-150/50 h-11 px-8 text-lg py-6"
      >
        Contactar
      </a>
    </div>
  </Section>
</Layout>

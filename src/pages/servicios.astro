---
import Layout from "../layouts/Layout.astro";
import Section from "../components/organismos/Section.astro";
---

<Layout>
  <Section class="bg-primary-bg-claro min-h-screen">
    <div class="max-w-4xl mx-auto my-24 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-primary-textoTitle mb-6">
        Servicios que brindamos
      </h1>
      <div
        class="max-w-2xl mx-auto text-left text-lg text-primary-textoBody bg-white p-8 rounded-2xl shadow-subtle border border-primary-border mt-8"
      >
        <ul class="space-y-6">
          <li class="flex items-center gap-3">
            <span class="w-3 h-3 rounded-full bg-primary-100 flex-shrink-0"
            ></span>
            <span>Talleres de Lecto escritura</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="w-3 h-3 rounded-full bg-primary-100 flex-shrink-0"
            ></span>
            <span>Taller de coro</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="w-3 h-3 rounded-full bg-primary-100 flex-shrink-0"
            ></span>
            <span>Taller para padres</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="w-3 h-3 rounded-full bg-primary-100 flex-shrink-0"
            ></span>
            <span>Atención de consultorio de Fonoaudiología y Psicología</span>
          </li>
        </ul>
      </div>
      <p class="text-lg text-primary-textoBody mt-8">
        Los niños que nacen con fisura labio palatina necesitan más que una
        cirugía. También pueden necesitar apoyo nutricional, atención dental,
        tratamiento de ortodoncia y terapia del habla
      </p>
    </div>
  </Section>
</Layout>

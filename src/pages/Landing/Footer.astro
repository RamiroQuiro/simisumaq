---
import { Facebook, Heart, Instagram, Twitter, Youtube } from "lucide-react";
import { FACEBOOK, INSTAGRAM, YOUTUBE } from "../../layouts/Layout.astro";

const socialMedia = [
  {
    icon: Facebook,
    name: "Facebook",
    link: FACEBOOK,
    color: "hover:text-blue-600",
  },
  {
    icon: Instagram,
    name: "Instagram",
    link: INSTAGRAM,
    color: "hover:text-pink-600",
  },
  {
    icon: Youtube,
    name: "Youtube",
    link: YOUTUBE,
    color: "hover:text-pink-600",
  },
];
---

<footer id="footer" class="bg-primary-textoTitle mt-12 text-white py-12">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-4 gap-8 mb-8">
      <div>
        <div class="flex items-center gap-2">
          <img src="./logo.jpeg" class="h-8 w-8 rounded-xl" />
          <span class="text-xl font-bold text-primary-100">Asociación</span>
          <span class="text-xl font-bold text-primary-200">Simi Sumaq</span>
        </div>
        <p class="text-white/80">
          Multiplicando sonrisas de niños con FLAP a través de un trabajo
          interdisciplinario
        </p>
      </div>

      <div>
        <h3 class="font-bold mb-4">Sobre Nosotros</h3>
        <ul class="space-y-2 text-white/80">
          <li>
            <a href="/sobre-nosotros" class="hover:text-white transition-colors"
              >Nuestra Historia</a
            >
          </li>
          <li>
            <a href="/equipo" class="hover:text-white transition-colors"
              >Equipo</a
            >
          </li>
          <li>
            <a href="/que-hacemos" class="hover:text-white transition-colors"
              >Qué Hacemos</a
            >
          </li>
          <li>
            <a href="/proyectos" class="hover:text-white transition-colors"
              >Impacto</a
            >
          </li>
          <li>
            <a
              href="/proyectos#resultados"
              class="hover:text-white transition-colors">Resultados</a
            >
          </li>
        </ul>
      </div>

      <div>
        <h3 class="font-bold mb-4">Ayuda</h3>
        <ul class="space-y-2 text-white/80">
          <li>
            <a href="/como-ayudar" class="hover:text-white transition-colors"
              >Donar</a
            >
          </li>
          <li>
            <a
              href="/como-ayudar#voluntariado"
              class="hover:text-white transition-colors">Voluntariado</a
            >
          </li>
          <li>
            <a href="/eventos" class="hover:text-white transition-colors"
              >Eventos</a
            >
          </li>
          <li>
            <a href="/contacto" class="hover:text-white transition-colors"
              >Contacto</a
            >
          </li>
        </ul>
      </div>

      <div>
        <h3 class="font-bold mb-4">Síguenos</h3>
        <div class="flex gap-4">
          <a
            href={FACEBOOK}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-primary transition-colors"
          >
            <Facebook className="h-6 w-6" />
          </a>
          <a
            href={INSTAGRAM}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-primary transition-colors"
          >
            <Instagram className="h-6 w-6" />
          </a>
          <a
            href={YOUTUBE}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-primary transition-colors"
          >
            <Youtube className="h-6 w-6" />
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-white/20 pt-8 text-center text-white/60">
      <p>&copy; hecho por <a href="https://ramacode.online">RamaCode</a>.</p>
    </div>
  </div>
</footer>

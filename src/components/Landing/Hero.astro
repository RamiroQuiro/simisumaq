---
import { ArrowRight } from "lucide-react";
import Button from "../../components/atomos/Button";
import Section from "../../components/organismos/Section.astro";
---

<Section isBackgroundFoto id="inicio" srcFotoBackground="/hero-image.webp">
  <div class="max-w-2xl">
    <h1
      class="text-5xl md:text-6xl lg:text-7xl font-bold text-primary-textoTitle mb-6 leading-tight"
    >
      Multiplicando sonrisas
    </h1>

    <p class="text-xl md:text-2xl text-primary-texto mb-8 leading-relaxed">
      Cada 3 minutos nace un niño o niña con labio y/o paladar hendido . Tu
      donación puede tranformar sonrisas y darles la oportunidad de de hacer con
      confianza y superar sus miedos
    </p>

    <div class="flex flex-col sm:flex-row gap-4">
      <Button
        weight="bold"
        size="lg"
        variant="primary"
        class="text-lg px-8 py-6 shadow-strong hover:shadow-medium transition-all"
      >
        Donar Ahora
        <ArrowRight class="ml-2 h-5 w-5" />
      </Button>
      <Button
        weight="bold"
        variant="secondary"
        size="lg"
        class="text-lg px-8 py-6 border-2"
      >
        Conoce Más
      </Button>
    </div>

    <div class="mt-12 grid grid-cols-3 gap-6">
      <div>
        <div class="text-4xl font-bold text-primary-texto mb-2">+200</div>
        <div class="text-sm text-primary-texto">Familias identificadas</div>
      </div>
      <div>
        <div class="text-4xl font-bold text-primary-texto mb-2">+20</div>
        <div class="text-sm text-primary-texto">
          Familias que asisten a los tallres
        </div>
      </div>
      <div>
        <div class="text-4xl font-bold text-accent mb-2">+10</div>
        <div class="text-sm text-muted-foreground">Años de impacto</div>
      </div>
    </div>
  </div>
</Section>

---
import Navbar from "../components/organismos/Navbar.astro";
import Footer from "../pages/Landing/Footer.astro";
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

export const SITE_URL = "https://simisumq.org";
export const EMAIL = "simisumaq@gmail.com";
export const TELEFONO = "+54 9 385 506-3501";
export const INSTAGRAM = "https://www.instagram.com/simi.sumaq/";
export const FACEBOOK = "https://www.facebook.com/simisumaq";
export const YOUTUBE = "https://www.youtube.com/@simisumaq7683";
const DEFAULT_TITLE =
  "Asociacion Simi Sumaq | Atencion integral de fisura labiopalatina";
const DEFAULT_DESCRIPTION =
  "Asociacion civil sin fines de lucro que brinda atencion interdisciplinaria a ninos y familias con fisura labiopalatina en Santiago del Estero.";
const DEFAULT_OG_IMAGE = `${SITE_URL}/logo.jpeg`;

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  canonical = SITE_URL + Astro.url.pathname,
  ogImage = DEFAULT_OG_IMAGE,
  noindex = false,
} = Astro.props;

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "NGO",
  name: "Asociacion Simi Sumaq",
  url: SITE_URL,
  logo: `${SITE_URL}/logo.jpeg`,
  description: DEFAULT_DESCRIPTION,
  email: EMAIL,
  telephone: TELEFONO,
  areaServed: "Santiago del Estero, Argentina",
  sameAs: [INSTAGRAM, FACEBOOK],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Asociacion Simi Sumaq" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta
      name="robots"
      content={noindex
        ? "noindex, nofollow"
        : "index, follow, max-image-preview:large"}
    />
    <meta name="theme-color" content="#2E86C1" />
    <meta name="format-detection" content="telephone=no" />
    <link rel="canonical" href={canonical} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <ClientRouter />
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    scroll-behavior: smooth;
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
